# AI API（必填）
AI_API_KEY=your_api_key_here

# API 地址（OpenAI 兼容格式）
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# 可选：单次回复最大 token
AI_MAX_TOKENS=2000

# 可选：魔杖外观图生成（OpenAI 兼容 images API，不填则仅文字+SVG 预览）
# IMAGE_API_KEY=sk-...
# IMAGE_BASE_URL=https://api.openai.com
# IMAGE_MODEL=dall-e-3

# 可选：每 IP 每日请求上限（0 = 不限制）
DAILY_LIMIT=50

# 可选：邀请码
# INVITE_CODE=hogwarts2026

# 本地开发端口
PORT=3000
